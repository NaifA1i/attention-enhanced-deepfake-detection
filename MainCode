# Squeeze-and-Excitation (SE) Block
def se_block(input_feature, reduction_ratio=16):
    se = GlobalAveragePooling2D()(input_feature)
    se = Dense(input_feature.shape[-1] // reduction_ratio, activation='relu')(se)
    se = Dense(input_feature.shape[-1], activation='sigmoid')(se)
    se = Reshape((1, 1, input_feature.shape[-1]))(se)
    return Multiply()([input_feature, se])

# Convolutional Block Attention Module (CBAM) Block
def cbam_block(input_feature, reduction_ratio=16):
    # Channel Attention
    channel_avg_pool = GlobalAveragePooling2D()(input_feature)
    channel_max_pool = GlobalMaxPooling2D()(input_feature)

    shared_dense_one = Dense(input_feature.shape[-1] // reduction_ratio, activation='relu',
                             kernel_initializer='he_normal')
    shared_dense_two = Dense(input_feature.shape[-1], kernel_initializer='he_normal')

    avg_dense = shared_dense_two(shared_dense_one(channel_avg_pool))
    max_dense = shared_dense_two(shared_dense_one(channel_max_pool))

    channel_attention = Activation('sigmoid')(Add()([avg_dense, max_dense]))
    channel_attention = Reshape((1, 1, input_feature.shape[-1]))(channel_attention)
    channel_refined = Multiply()([input_feature, channel_attention])

    # Spatial Attention
    avg_pool = tf.reduce_mean(channel_refined, axis=-1, keepdims=True)
    max_pool = tf.reduce_max(channel_refined, axis=-1, keepdims=True)
    concat = tf.concat([avg_pool, max_pool], axis=-1)

    spatial_attention = Conv2D(1, kernel_size=7, strides=1, padding='same', activation='sigmoid',
                               kernel_initializer='he_normal')(concat)
    refined_feature = Multiply()([channel_refined, spatial_attention])

    return refined_feature
# Function to create and compile a model
def create_model(base_model):
    x = base_model.output

    # Keep the 4D Spatial Structure (Avoid Flattening)
    y = Conv2D(1024, (3, 3), activation='relu', padding='same')(x)
    y = BatchNormalization()(y)
    y = se_block(y) #SE
    y = cbam_block(y) #CBAM
    y = MaxPooling2D(pool_size=(2, 2))(y)

    y = Conv2D(1024, (3, 3), activation='relu', padding='same')(y)
    y = BatchNormalization()(y)
    y = se_block(y) #SE
    y = cbam_block(y) #CBAM
    y = MaxPooling2D(pool_size=(2, 2))(y)

    y = GlobalAveragePooling2D()(y)
    y = Dense(1024, activation='relu')(y)
    y = Dropout(0.4)(y)
    y = Dense(512, activation='relu')(y)
    y = Dropout(0.4)(y)
    y = Dense(256, activation='relu')(y)
    y = Dropout(0.3)(y)
    # layers.Concatenate
    x = Concatenate()([GlobalAveragePooling2D()(x), y])
    # Output Layer


    predictions = Dense(1, activation='sigmoid')(x)

    model = Model(inputs=base_model.input, outputs=predictions)
    base_model.trainable = False
    model.compile(optimizer=Adam(learning_rate=0.0001), loss='binary_crossentropy', metrics=['accuracy', tf.keras.metrics.AUC(name='auc')])

    return model

# List of pre-trained models to use
base_models = [
