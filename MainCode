]

# Function to plot training loss vs. training accuracy for a single model
def plot_history(history, model_name):
    acc = history.history['accuracy']
    loss = history.history['loss']
    epochs_range = range(len(acc))

    plt.figure(figsize=(12, 6))
    plt.plot(epochs_range, acc, label='Training Accuracy')
    plt.plot(epochs_range, loss, label='Training Loss')
    plt.legend(loc='best')
    plt.title(f'{model_name} - Training Loss vs. Training Accuracy (BasedLine_Concatenate_SE_CBAM)')
    plt.xlabel('Epochs')
    plt.ylabel('Value')
    plt.savefig(f'{model_name}_training_loss_vs_accuracy_BasedLine_Concatenate_SE_CBAM.png')
    plt.show()

# Function to plot the confusion matrix for a single model
def plot_confusion_matrix(cm, model_name):
    disp = ConfusionMatrixDisplay(confusion_matrix=cm, display_labels=['Fake', 'Real'])
    disp.plot(cmap=plt.cm.Blues)
    plt.title(f'{model_name} - Confusion Matrix (BasedLine_Concatenate_SE_CBAM)')
    plt.savefig(f'{model_name}_confusion_matrix_BasedLine_Concatenate_SE_CBAM.png')
    plt.show()

# Function to display images from a generator
def display_images(generator, num_images):
    images, labels = next(generator)
    plt.figure(figsize=(12, 12))
    for i in range(num_images):
        plt.subplot(4, 4, i + 1)
        plt.imshow(images[i])
        plt.title('Real' if labels[i] == 1 else 'Fake')
        plt.axis('off')
    plt.show()

